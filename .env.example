# =====================================================================
# Paise — Environment variables (template)
# =====================================================================
# Copy this file to `.env.local` and fill in your keys.
# The app runs WITHOUT any of these set — auth is stub-based, data is
# localStorage, AI falls back to canned responses. Fill keys in to
# enable the real integrations.
# =====================================================================

# --- Anthropic (Claude API) -----------------------------------------
# Get from https://console.anthropic.com/
# Without this: chatbot, FD ladder explanations and expense insights
# return helpful canned fallbacks.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- Supabase (Postgres + Auth) --------------------------------------
# Get from https://supabase.com/ → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Resend (transactional email) ------------------------------------
# Get from https://resend.com/
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=Paise <onboarding@resend.dev>

# --- App settings ----------------------------------------------------
# Email of the first admin. This email, on signup, is auto-promoted
# to the admin role. Can be changed later from /admin/users.
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

# --- Public app URL (used for referral share links) ------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
